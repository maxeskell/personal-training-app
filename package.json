{
  "name": "endurance-coach",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Personal AI endurance coach — local-first orchestrator",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "setup": "tsx src/cli.ts setup",
    "profile:init": "tsx src/cli.ts profile-init",
    "profile:questions": "tsx src/cli.ts profile-questions",
    "start": "tsx src/server.ts",
    "help": "tsx src/cli.ts help",
    "auth:aie": "tsx src/cli.ts auth",
    "verify:reads": "tsx src/cli.ts verify",
    "doctor": "tsx src/cli.ts doctor",
    "health-remote": "tsx src/cli.ts health-remote",
    "healthcheck:install": "bash scripts/install-healthcheck.sh",
    "healthcheck:uninstall": "bash scripts/uninstall-healthcheck.sh",
    "state:today": "tsx src/cli.ts state",
    "readiness": "tsx src/cli.ts readiness",
    "weekly": "tsx src/cli.ts weekly",
    "race": "tsx src/cli.ts race",
    "propose": "tsx src/cli.ts propose",
    "confirm": "tsx src/cli.ts confirm",
    "decline": "tsx src/cli.ts decline",
    "ping": "tsx src/cli.ts ping",
    "dashboard": "tsx src/cli.ts dashboard",
    "demo": "tsx src/cli.ts demo",
    "decisions": "tsx src/cli.ts decisions",
    "schedule:install": "bash scripts/install-schedule.sh",
    "schedule:uninstall": "bash scripts/uninstall-schedule.sh",
    "serve": "tsx src/server.ts",
    "mcp": "tsx src/mcpServer.ts",
    "mcp:http": "tsx src/mcpHttp.ts",
    "mcp:install": "bash scripts/install-mcp.sh",
    "mcp:uninstall": "bash scripts/uninstall-mcp.sh",
    "mcp:logs": "tail -n 40 -f reports/mcp.log",
    "serve:install": "bash scripts/install-server.sh",
    "serve:uninstall": "bash scripts/uninstall-server.sh",
    "service:install": "npm run serve:install && npm run autoupdate:install",
    "service:uninstall": "npm run autoupdate:uninstall && npm run serve:uninstall",
    "serve:logs": "tail -n 40 -f reports/server.log",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop endurance-dashboard",
    "deep-dive": "tsx src/cli.ts deep-dive",
    "season": "tsx src/cli.ts season",
    "act": "tsx src/cli.ts act",
    "check": "tsx src/cli.ts check",
    "watch:install": "bash scripts/install-watch.sh",
    "watch:uninstall": "bash scripts/uninstall-watch.sh",
    "ask": "tsx src/cli.ts ask",
    "session": "tsx src/cli.ts session",
    "splits": "tsx src/cli.ts splits",
    "ingest-fit": "tsx src/cli.ts ingest-fit",
    "career:build": "tsx scripts/build-career-history.ts",
    "ftp-check": "tsx src/cli.ts ftp-check",
    "cost": "tsx src/cli.ts cost",
    "listening": "tsx src/cli.ts listening",
    "tune": "tsx src/cli.ts tune",
    "fuelling": "tsx src/cli.ts fuelling",
    "fuel-review": "tsx src/cli.ts fuel-review",
    "research": "tsx src/cli.ts research",
    "knowledge": "tsx src/cli.ts knowledge",
    "test": "tsx --test test/*.test.ts",
    "probe": "tsx src/cli.ts probe",
    "fit-sync": "tsx src/cli.ts fit-sync",
    "backfill": "tsx src/cli.ts backfill",
    "archive:import": "tsx src/cli.ts archive-import",
    "archive:backfill": "tsx src/cli.ts archive-backfill",
    "backfill:status": "tsx src/cli.ts archive-status",
    "backfill:compact": "tsx src/cli.ts archive-compact",
    "backfill:install": "bash scripts/install-backfill.sh",
    "backfill:uninstall": "bash scripts/uninstall-backfill.sh",
    "update": "bash scripts/autoupdate.sh",
    "autoupdate:install": "bash scripts/install-autoupdate.sh",
    "autoupdate:uninstall": "bash scripts/uninstall-autoupdate.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.0",
    "open": "^10.1.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
