# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- AI Endurance (required spine) ---
# Defaults are correct for the public server; override only if needed.
# AIE_MCP_URL=https://aiendurance.com/mcp
# AIE_OAUTH_PORT=8765            # loopback port for the OAuth redirect

# --- Garmin (optional, degradable gap-filler) ---
GARMIN_ENABLED=false
# One-time auth before enabling (saves tokens to ~/.garminconnect, ~6mo lifetime):
#   uvx --python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp garmin-mcp-auth
# GARMIN_MCP_COMMAND=uvx
# Default pins the garmin_mcp commit that added download_activity_file (raw .FIT auto-download) — if
# you override, keep a pin ≥ d31de79 or stream auto-download degrades to manual export.
# GARMIN_MCP_ARGS=--python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp@d31de7980d652289e5368637261fcd17aa2c7d90 garmin-mcp
# GARMIN_TIMEOUT_MS=15000

# --- Local LLM server (optional, degradable) ---
# An OpenAI-compatible Ollama wrapper (see the local-llm-server repo) used ONLY for cheap, low-stakes
# side tasks — currently `ask` intent routing (deciding if a question is about one specific session).
# Coaching output always stays on Opus. Off by default: the zero-cost regex fast-path handles routing,
# and the local model only backstops it on paraphrases the regex misses. Failures fall back to regex,
# so a missing/slow server never breaks or blocks the Q&A.
COACH_LOCAL_INTENT=false
# LOCAL_LLM_URL=http://localhost:8000/v1   # base URL incl. the /v1 prefix
# LOCAL_LLM_API_KEY=                        # bearer token; empty if the server has auth disabled
# LOCAL_LLM_MODEL=llama3.2:1b               # any model the server/Ollama has pulled
# LOCAL_LLM_TIMEOUT_MS=4000                 # hard timeout before falling back to regex

# --- Storage ---
# COACH_SECRETS_DIR=~/.endurance-coach   # OAuth tokens (outside repo by default)
# COACH_DATA_DIR=./data                  # daily AthleteState (gitignored)

# --- Stream-level (.FIT) analysis (optional) ---
# Point this at a directory of RAW Garmin .FIT activity files (decoded in-process — no extraction step)
# to unlock within-session signals: aerobic decoupling (power/speed:HR drift), per-activity temperature
# (heat confounder), and run biomechanics (cadence drop / GCT rise on HRM-strap runs). Pre-extracted
# JSON streams are also accepted. Defaults to ./data/fit-streams if unset — `npm run fit-sync` (and the
# dashboard Sync) downloads recent raw .FIT files there automatically (via download_activity_file); manual
# export (Garmin Connect → ⚙ → Export Original) remains the fallback for older builds/activities.
# FIT_STREAMS_DIR=./data/fit-streams
