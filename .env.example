# Copy to .env and fill in. .env is gitignored — never commit real values.
#
# ── Don't be put off by the length ──────────────────────────────────────────────
# EVERYTHING here is OPTIONAL except ANTHROPIC_API_KEY (and even that is only needed for the AI
# write-ups). Every other line has a safe default — you can run the coach with an almost-empty .env.
# The three most people set:
#     ANTHROPIC_API_KEY=sk-ant-...              # for readiness/weekly/race/ask/… (skip for dashboard-only use)
#     COACH_UNITS=metric, UK                    # or "imperial, US"
#     COACH_WEATHER_LAT= / COACH_WEATHER_LON=   # where you train, for the weather card
# Everything below that is "advanced — change only if you know you need to."
# ────────────────────────────────────────────────────────────────────────────────

# --- Data source (training-data spine) ---
# Which spine the coach assembles from. "ai-endurance" is the default and most capable; "intervals" uses
# intervals.icu instead (see below). Unknown values fall back to AI Endurance. (src/sources/, docs/data-sources.md)
# COACH_SOURCE=ai-endurance

# --- intervals.icu (alternative spine; only when COACH_SOURCE=intervals — EXPERIMENTAL) ---
# A free, popular platform. Read-only here, and a thinner coach than AI Endurance (no DFA-α1 durability,
# AIE race predictions or plan-progress adherence — those cards degrade). Get your key + athlete id from
# intervals.icu → Settings → Developer.
# COACH_INTERVALS_API_KEY=
# COACH_INTERVALS_ATHLETE_ID=i123456
# COACH_INTERVALS_URL=https://intervals.icu/api/v1   # override only if self-hosting
# COACH_INTERVALS_WINDOW_DAYS=60                      # trailing activities/wellness window
# COACH_INTERVALS_TIMEOUT_MS=15000

# --- AI Endurance (required spine) ---
# Defaults are correct for the public server; override only if needed.
# AIE_MCP_URL=https://aiendurance.com/mcp
# AIE_OAUTH_PORT=8765            # loopback port for the OAuth redirect
# AIE_TIMEOUT_MS=20000           # hard cap on a connect to AI Endurance — a headless flow (server/cron/
#                                # Cowork) fails fast with a "run npm run auth:aie" error instead of
#                                # blocking on a browser that can't appear. The interactive `auth` wait is exempt.

# --- Anthropic API (required for the LLM coaching flows) ---
# Needed for readiness/weekly/race/propose/deep-dive/ask/session. The deterministic flows
# (verify, doctor, state, check, dashboard cards, weather) make no LLM call and need no key.
# Get one at https://console.anthropic.com. Keep it here (.env is gitignored) or export it in
# your shell. Leave blank to run the no-LLM flows only.
ANTHROPIC_API_KEY=
# Optional: override the per-million-token rates used ONLY for the local cost log (never sent).
# COACH_PRICE_INPUT=5
# COACH_PRICE_OUTPUT=25
# COACH_PRICE_CACHE_WRITE=6.25         # 5-minute-TTL cache-write rate (1.25× input)
# COACH_PRICE_CACHE_READ=0.5           # cache-read rate (0.1× input)

# --- Garmin (optional, degradable gap-filler) ---
GARMIN_ENABLED=false
# One-time auth before enabling (saves tokens to ~/.garminconnect, ~6mo lifetime):
#   uvx --python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp garmin-mcp-auth
# GARMIN_MCP_COMMAND=uvx
# Default pins the garmin_mcp commit that added download_activity_file (raw .FIT auto-download) — if
# you override, keep a pin ≥ d31de79 or stream auto-download degrades to manual export.
# GARMIN_MCP_ARGS=--python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp@d31de7980d652289e5368637261fcd17aa2c7d90 garmin-mcp
# GARMIN_TIMEOUT_MS=25000              # hard cap (ms) on any single Garmin call — some endpoints
#                                      # (power-duration curve, race predictions) parse many activities and are slow
# GARMIN_REFRESH_BUDGET_MS=90000       # overall wall-clock budget for the whole Garmin phase of one /refresh; past
#                                      # it remaining reads are skipped (degrade to AIE-only) so one slow tool can't hang a sync

# --- `ask` intent routing (optional) ---
# How the `ask` box decides if a question is about ONE specific session (→ the deep single-session
# pipeline) vs a general question. Three strategies; ALL degrade to the zero-cost regex on any error,
# and coaching output always stays on Opus regardless:
#   regex  (default) — pure regex, no model, no cost.
#   haiku            — a cheap claude-haiku-4-5 micro-call on your EXISTING ANTHROPIC_API_KEY (no extra
#                      server to run). Recommended upgrade over regex: catches paraphrases it misses, costs
#                      a fraction of a cent, and is cost-logged like any other call. Needs ANTHROPIC_API_KEY.
#   local            — the separate local-llm-server (Ollama). Advanced; only if you want zero API cost and
#                      don't mind running it. (Legacy: COACH_LOCAL_INTENT=true also selects this.)
COACH_INTENT_ROUTER=regex
# Haiku price overrides ($/MTok) for the local cost log — published claude-haiku-4-5 rates; set if they change:
# COACH_PRICE_HAIKU_INPUT=1
# COACH_PRICE_HAIKU_OUTPUT=5
# COACH_PRICE_HAIKU_CACHE_WRITE=1.25
# COACH_PRICE_HAIKU_CACHE_READ=0.1

# --- Local LLM server (advanced; only when COACH_INTENT_ROUTER=local) ---
# An OpenAI-compatible Ollama wrapper (see the local-llm-server repo). Off by default; a missing/slow
# server falls back to regex so it never breaks the Q&A.
COACH_LOCAL_INTENT=false
# LOCAL_LLM_URL=http://localhost:8000/v1   # base URL incl. the /v1 prefix
# LOCAL_LLM_API_KEY=                        # bearer token; empty if the server has auth disabled
# LOCAL_LLM_MODEL=llama3.2:1b               # any model the server/Ollama has pulled
# LOCAL_LLM_TIMEOUT_MS=4000                 # hard timeout before falling back to regex

# --- Cross-source de-dup of the "Coach's recommendations" card (advanced; uses the same server) ---
# When on, a SYNC-TIME pass embeds each recommendation via the local-llm-server's /v1/embeddings and the
# deterministic render collapses the same idea phrased differently across readiness/deep-dive/ask into one
# line (cosine similarity, computed off the render path). Off by default; needs a pulled embedding model
# (`ollama pull nomic-embed-text`). Degrades to the per-source grouping if the server/model is unavailable.
COACH_ADVICE_CLUSTERING=false
# LOCAL_LLM_EMBED_MODEL=nomic-embed-text    # embedding model the server should use (must be pulled in Ollama)
# COACH_ADVICE_CLUSTER_SIMILARITY=0.86      # cosine threshold (0–1) above which two recs are the same idea
# LOCAL_LLM_EMBED_TIMEOUT_MS=5000           # hard timeout for the embeddings call (never stalls a sync)

# --- Week-ahead weather (dashboard "Week ahead — plan vs weather" card) ---
# Open-Meteo, free, no key. Coordinates default to a neutral location (London) — set these to where
# you ride/run/swim from. Set COACH_WEATHER_ENABLED=false to drop the card entirely.
# COACH_WEATHER_ENABLED=true
# COACH_WEATHER_LAT=51.5074
# COACH_WEATHER_LON=-0.1278
# Open-water rules: your comfort floor, plus the venue's latest POSTED water temp (there is no public
# live feed). The everyday way to set the temp is the water-temp box on the dashboard's "Week ahead"
# card — it saves live (to data/venue.json) with no restart, and that reading WINS over the var below.
# Once a reading is >7 days old the coach forecasts the temp (your reading drifted on air temperature, a
# MODEL) and asks you to Confirm/Correct it. COACH_WATER_TEMP_C is now just an optional SEED used before
# your first reading; leave it unset to start with a "check the venue" nudge.
# COACH_SWIM_MIN_WATER_C=13
# COACH_WATER_TEMP_C=
# Ride comfort thresholds for the verdicts + daylight ride windows:
# COACH_RIDE_MAX_GUST_KMH=38
# COACH_RIDE_MAX_RAIN_PROB=40
# COACH_WEATHER_TIMEOUT_MS=6000        # hard timeout (ms) on the Open-Meteo fetch; past it the card degrades to a note

# Swim CSS (Critical Swim Speed) fallback — pace per 100m. AI Endurance's getUser doesn't always expose
# the CSS you set in its UI; like COACH_WATER_TEMP_C (no public feed), set it here so the dashboard still
# builds a swim model (zones + race swim split). Accepts m:ss (e.g. 1:52) or bare seconds (e.g. 112). A
# swim CSS that DOES come through from AI Endurance always wins over this fallback.
# COACH_SWIM_CSS=

# --- Dashboard server (bind address + auth) ---
# The local always-on dashboard (installed once with `npm run serve:install`). Defaults serve localhost only.
# COACH_PORT=3000                      # port the dashboard listens on
# COACH_LAN=0                          # 1 = also bind your LAN so a phone on the same Wi-Fi can reach it (off → localhost
#                                      #   only). When on, the Host header is allow-listed to the machine's own IPs (anti DNS-rebind).
# COACH_HOST=127.0.0.1                 # interface to bind; defaults to 0.0.0.0 when COACH_LAN=1, else 127.0.0.1
# COACH_TOKEN=                         # per-install secret (cookie/header) gating every route — the server can reach AIE
#                                      #   writes and spend LLM budget. Unset → a random token is written to
#                                      #   <secretsDir>/dashboard.token (0600) and used automatically.

# --- Dashboard auto-sync ---
# A page load whose data snapshot is older than this many minutes kicks a background Sync and
# reloads when done (the page still renders instantly from the snapshot). 0 disables auto-sync.
# COACH_AUTOSYNC_MIN=30

# --- Deep session feedback (auto-generated at sync) ---
# Deep per-session feedback is generated automatically at sync and shown inline on the dashboard's
# "Last session" card (no button). Each session generated is ONE LLM call, so this throttles it:
#   on     = every recent session that has its raw .FIT (default)
#   latest = only the single most recent session
#   off    = none — generate on demand with `npm run session` instead
# COACH_AUTO_SESSION_FEEDBACK=on

# --- Code auto-update (npm run update / the autoupdate timer) ---
# The branch the auto-updater pulls and restarts onto. It tracks THIS branch regardless of what's
# currently checked out (switching back to it on a clean tree), so a stale feature branch can't make
# updates silently no-op. Default 'main' — only change it if you deploy from a different branch.
# COACH_DEPLOY_BRANCH=main

# --- Athlete identity ---
# Name, age, sex and thresholds come LIVE from AI Endurance getUser; races/season shape come live from
# getRaceGoalEvent (nothing about your calendar is hard-coded). These two are the only bits getUser
# doesn't expose — device kit and unit preference. Clear COACH_EQUIPMENT to drop the kit line entirely.
# COACH_EQUIPMENT=Garmin Forerunner 970, Edge 1040, Index scale
# COACH_UNITS=metric, UK
# IANA timezone used to decide which calendar day "today" is (so a late-night BST session isn't
# mis-dated to the previous UTC day, and the dose_cycle lands on the right weekday). Resolution:
# COACH_TZ (if set here) → the profile's identity.timezone → Europe/London. Set this only to override
# the profile (e.g. travelling); otherwise just set identity.timezone in profile.local.yaml.
# COACH_TZ=Europe/London

# --- Athlete profile (stable context: body, kit, medical, availability, race targets) ---
# Stored in profile.local.yaml (gitignored) — copy profile.example.yaml and run `npm run profile:init`.
# Holds only what no API exposes; NEVER live numbers (FTP/weight/HRV/CSS come live from AIE/Garmin).
# Resolution is COACH_PROFILE_PATH (this var) → profile.local.yaml → profile.example.yaml; set this to
# point at a profile file elsewhere (relative paths resolve from the repo root).
# COACH_PROFILE_PATH=profile.local.yaml

# --- MCP server (interrogate the coach from a Claude client) ---
# `npm run mcp` speaks MCP over stdio — use it from Claude Desktop / Claude Code (local).
# `npm run mcp:http` speaks MCP over HTTP for clients that can only reach a remote URL — notably
# Claude Cowork, whose sandboxed cloud VM can't spawn a local stdio server. Run it locally and expose
# it through an AUTHENTICATED HTTPS tunnel — Tailscale Funnel recommended (free, no domain, stable
# URL; cloudflared named tunnel if you own a domain); see docs/mcp-server.md.
# It binds to localhost and REQUIRES auth on every request (this exposes your health data and, unless
# read-only, the gated write tools — never run HTTP mode without auth + a private tunnel).
# COACH_MCP_HOST=127.0.0.1               # interface to bind (keep localhost; the tunnel reaches it)
# COACH_MCP_PORT=8787                    # local port the HTTP server listens on
# COACH_MCP_TOKEN=                       # the secret; if unset a random one is written to <secretsDir>/mcp.token (0600).
#                                        #   auth=token → sent as `Authorization: Bearer`; auth=oauth → typed into the consent page.
#                                        #   Must be >=16 chars in token/oauth modes — the server refuses to start with a weaker secret.
# COACH_MCP_READONLY=false               # true = drop propose/confirm/decline from the HTTP surface (reads only)
# COACH_MCP_PROFILE_WRITE=false          # true = expose the local-file `update_profile` tool on the HTTP/Cowork
#                                        #   surface, so you can fill profile.local.yaml by talking to Claude Cowork.
#                                        #   OFF by default (it lets a REMOTE session write a file on your Mac).
#                                        #   Always available to local Claude Desktop/Code regardless. Validated —
#                                        #   the no-live-numbers guard rejects FTP/weight/HRV/etc. either way.
# COACH_MCP_FILE_ACCESS=false            # true = expose the repo file tools (read_file/write_file/list_files)
#                                        #   on the HTTP/Cowork surface, so a remote session can read+update the
#                                        #   project's gitignored files (profile.local.yaml, data/, reports/,
#                                        #   knowledge/). OFF by default (it lets a REMOTE session read/write files
#                                        #   on your Mac). Always on for local Claude Desktop/Code. HARD-scoped to
#                                        #   the repo with a secrets deny-list — .env*, *.token(s)/keys, .git/ and
#                                        #   node_modules/ are NEVER readable or writable, whatever this is set to.
# COACH_MCP_AUTH=token                   # token | oauth | none.  Cowork's custom connectors need `oauth`
#                                        #   (OAuth 2.1: dynamic registration + PKCE + a coach-token-gated consent).
#                                        #   `token` suits scripts/self-hosted Desktop-over-HTTP; `none` only behind a private tunnel.
# COACH_MCP_PUBLIC_URL=                  # REQUIRED when auth=oauth: your public HTTPS tunnel URL, e.g.
#                                        #   https://<your-mac>.<tailnet>.ts.net (the OAuth issuer must be publicly reachable, not localhost)
#                                        #   Also read by `npm run health-remote` to know which URL to probe.
# The HTTP server exposes an UNAUTHENTICATED GET /health (info-only: status/version/readOnly, no secrets).
#   /health        — cheap liveness, no network ("is the server + tunnel up?" in one curl)
#   /health?deep=1 — also probes the AI Endurance spine → aie: ok | reauth_needed | unreachable
# `npm run health-remote` hits <COACH_MCP_PUBLIC_URL>/health?deep=1 and alerts (macOS) on trouble; schedule
#   it hands-free with `npm run healthcheck:install -- <https-url>` (see docs/mcp-server.md).

# --- Storage ---
# COACH_SECRETS_DIR=~/.endurance-coach   # OAuth tokens (outside repo by default)
# COACH_DATA_DIR=./data                  # daily AthleteState (gitignored)
# COACH_ARCHIVE_DIR=data/activity-archive  # durable, portable archive of your RAW activity files (.fit/.tcx/
#                                        #   .pwx/.gpx, gzipped or not), deduped by content. `npm run archive:import
#                                        #   -- --from <export>` seeds it; the Sync auto-archives every new .FIT.
#                                        #   Kept SEPARATE from data/fit-streams (so it never slows the dashboard).
# COACH_ARCHIVE_HEAL_CHUNK=200           # max .FIT files `npm run archive:heal` pulls per run (the scheduled
#                                        #   auto-heal that refills gaps; bounded so a catch-up grinds gently).
# COACH_CAREER_PATH=data/career-history.json  # data for the read-only /career page (race log + lifetime PBs
#                                        #   vs current form + power curve). GITIGNORED; build it from your
#                                        #   TrainingPeaks/intervals.icu archive + exported .FIT files with
#                                        #   `npm run career:build` (see SETUP.md → "Career history"). Race
#                                        #   performance + splits are read from your .FIT files (FIT_STREAMS_DIR
#                                        #   below, or --fit-dir); absent file → the page shows an empty state.

# --- Stream-level (.FIT) analysis (optional) ---
# Point this at a directory of RAW Garmin .FIT activity files (decoded in-process — no extraction step)
# to unlock within-session signals: aerobic decoupling (power/speed:HR drift), per-activity temperature
# (heat confounder), and run biomechanics (cadence drop / GCT rise on HRM-strap runs). Pre-extracted
# JSON streams are also accepted. Defaults to ./data/fit-streams if unset — `npm run fit-sync` (and the
# dashboard Sync) downloads recent raw .FIT files there automatically (via download_activity_file); manual
# export (Garmin Connect → ⚙ → Export Original) remains the fallback for older builds/activities.
# FIT_STREAMS_DIR=./data/fit-streams
